# =============================================================================
# ForkCart Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Database
DATABASE_URL=postgresql://forkcart:forkcart@localhost:5432/forkcart

# API Server
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Session
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Admin Panel
NEXT_PUBLIC_API_URL=http://localhost:4000

# Storefront
NEXT_PUBLIC_STOREFRONT_API_URL=http://localhost:4000

# AI Providers (optional — configure the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Stripe (optional — for payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Media Storage
MEDIA_STORAGE_PATH=./uploads
MEDIA_BASE_URL=http://localhost:4000/uploads

# Plugin Secrets Encryption
# Required for encrypting plugin secrets (generate with: openssl rand -hex 32)
FORKCART_ENCRYPTION_KEY=

# Logging
LOG_LEVEL=info
