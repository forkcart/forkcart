{
  "name": "@forkcart/plugin-sdk",
  "version": "0.1.0",
  "description": "SDK for building ForkCart plugins — types, helpers, and definePlugin().",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "forkcart",
    "plugin",
    "sdk",
    "ecommerce"
  ],
  "license": "MIT"
}
