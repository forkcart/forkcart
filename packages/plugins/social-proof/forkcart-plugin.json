{
  "name": "Social Proof",
  "slug": "social-proof",
  "packageName": "@forkcart/plugin-social-proof",
  "version": "1.0.0",
  "type": "general",
  "description": "Show real-time social proof notifications — recent purchases, visitor counts, and trending badges to boost conversions.",
  "author": "ForkCart",
  "license": "MIT",
  "minForkcartVersion": "0.1.0",
  "entryPoint": "dist/index.js",
  "settingsSchema": [
    { "key": "enabled", "type": "boolean", "label": "Enable Social Proof", "default": true },
    {
      "key": "showRecentPurchases",
      "type": "boolean",
      "label": "Show Recent Purchases",
      "default": true
    },
    {
      "key": "showVisitorCount",
      "type": "boolean",
      "label": "Show Visitor Count",
      "default": true
    },
    {
      "key": "showTrendingBadge",
      "type": "boolean",
      "label": "Show Trending Badge",
      "default": true
    },
    {
      "key": "notificationDelay",
      "type": "number",
      "label": "Notification Delay (seconds)",
      "default": 5
    },
    {
      "key": "maxNotifications",
      "type": "number",
      "label": "Max Notifications per Page",
      "default": 3
    }
  ]
}
